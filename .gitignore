# ── Secrets — never commit ──────────────────────────────────────
# All env files (the .env.example template can still be committed
# explicitly with `git add -f .env.example` if you want to share it)
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials/

# ── OS / editor noise ───────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# ── Claude Code local state ─────────────────────────────────────
.claude/

# ── Dependencies & build output ─────────────────────────────────
node_modules/
dist/
build/
.next/
out/
coverage/

# ── Logs ────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Misc ────────────────────────────────────────────────────────
*.zip
.cache/
